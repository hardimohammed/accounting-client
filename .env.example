# ============================================================
#  accounting-client — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  CRA only reads variables prefixed with REACT_APP_.
# ============================================================

# Backend API base URL. In dev, the "proxy" field in package.json
# forwards API calls to localhost:5000, so this can stay unset —
# only needed once deployed (point it at your Render backend URL).
REACT_APP_API_URL=https://your-backend.onrender.com/api/v1

# Sentry error tracking (optional — leave blank to disable)
REACT_APP_SENTRY_DSN=
